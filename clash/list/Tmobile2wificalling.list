# 内容：T-mobile wifi-calling

# 域名关键字匹配 - - - - - - - - - - - - - -x
DOMAIN-KEYWORD,t-mobile
DOMAIN-KEYWORD,t-mo
DOMAIN-KEYWORD,3gppnetwork

#域名走Tmobile分组代理 - - - - - - - - - - - - - -x
DOMAIN,epdg.epc.mnc240.mcc310.pub.3gppnetwork.org
DOMAIN,epdg.epc.mnc260.mcc310.pub.3gppnetwork.org
DOMAIN,ss.epdg.epc.mnc260.mcc310.pub.3gppnetwork.org
DOMAIN,ss.epdg.epc.geo.mnc260.mcc310.pub.3gppnetwork.org
DOMAIN,crl.t-mobile.com
DOMAIN,eas3.msg.t-mobile.com
DOMAIN,mascns.t-mobile.com
DOMAIN,ns.sipgeo.t-mobile.com

# 解决dl.google.com 404
DOMAIN,dl.google.com

# 域名后缀匹配 - - - - - - - - - - - - - -x
DOMAIN-SUFFIX,t-mobile.com
DOMAIN-SUFFIX,t-mo.co
DOMAIN-SUFFIX,3gppnetwork.org

